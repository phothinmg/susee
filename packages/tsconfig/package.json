{
  "name": "@suseejs/tsconfig",
  "version": "0.1.3",
  "description": "Get TypeScript compiler options and tsconfig file",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.cts",
  "exports": {
    ".": {
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      },
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    }
  },
  "scripts": {
    "build": "tsc",
    "lint": "biome check src --write",
    "fmt": "biome format --write"
  },
  "keywords": [
    "suseejs"
  ],
  "author": {
    "name": "Pho Thin Mg",
    "email": "phothinmg@disroot.org",
    "url": "https://phothinmg.github.io/"
  },
  "license": "Apache-2.0",
  "repository": {
    "url": "git+https://github.com/phothinmg/susee.git",
    "type": "git"
  },
  "bugs": {
    "url": "https://github.com/phothinmg/susee/issues"
  },
  "homepage": "https://github.com/phothinmg/susee/blob/main/packages/tsconfig/README.md",
  "files": [
    "dist/**/*",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/node": "^25.6.0"
  },
  "dependencies": {
    "@suseejs/tcolor": "file:../tcolor",
    "typescript": "^6.0.2"
  }
}
