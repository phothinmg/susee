{
  "name": "@suseejs/types",
  "version": "0.2.2",
  "description": "Type definitions for suseejs",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.cts",
  "exports": {
    ".": {
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      },
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    }
  },
  "scripts": {
    "commonjs": "tsc -p tsconfig.commonjs.json",
    "esm": "tsc -p tsconfig.esm.json",
    "build": "npm run esm && npm run commonjs"
  },
  "keywords": [
    "suseejs"
  ],
  "author": {
    "name": "Pho Thin Mg",
    "email": "phothinmg@disroot.org",
    "url": "https://phothinmg.github.io/"
  },
  "license": "Apache-2.0",
  "repository": {
    "url": "git+https://github.com/phothinmg/susee.git",
    "type": "git"
  },
  "bugs": {
    "url": "https://github.com/phothinmg/susee/issues"
  },
  "homepage": "https://github.com/phothinmg/susee/blob/main/packages/types/README.md",
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "typescript": "^6.0.2"
  }
}
