{
	"name": "susee",
	"version": "1.0.1",
	"description": "Tiny TypeScript Bundler",
	"type": "module",
	"main": "dist/index.cjs",
	"types": "dist/index.d.cts",
	"module": "dist/index.mjs",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		}
	},
	"bin": {
		"susee": "bin/index.mjs"
	},
	"scripts": {
		"build": "tsx build.ts",
		"test": "tsx --test",
		"coverage": "tsx tests/lib/index.ts",
		"test:sc": "tsx --test tests/initialization/suseeConfig.test.ts",
		"test:dep": "tsx --test tests/initialization/dependencies.test.ts",
		"test:init": "tsx --test tests/initialization/initializer.test.ts",
		"test:tco": "tsx --test tests/initialization/dependencies.test.ts",
		"fmt": "biome format --write",
		"lint": "biome check src --write && biome check tests --write",
		"prepare": "husky"
	},
	"keywords": [
		"bundler"
	],
	"author": {
		"name": "Pho Thin Mg",
		"email": "phothinmg@disroot.org",
		"url": "https://phothinmg.github.io/"
	},
	"license": "Apache-2.0",
	"dependencies": {
		"@phothinmaung/resolves": "^1.0.0",
		"@suseejs/tcolor": "^0.1.0",
		"@suseejs/transformer": "^0.1.0",
		"@suseejs/tsconfig": "^0.1.1",
		"@suseejs/types": "^0.1.11",
		"@suseejs/utils": "^0.1.3",
		"mhaehko": "^0.1.0",
		"typescript": "^5.9.3"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.13",
		"@suseejs/plugin-banner-text": "^0.1.4",
		"@suseejs/plugin-terser": "^1.0.2",
		"@types/node": "^25.1.0",
		"husky": "^9.1.7",
		"tsx": "^4.21.0"
	},
	"files": [
		"package.json",
		"README.md",
		"LICENSE",
		"dist/**/*",
		"bin/**/*"
	],
	"publishConfig": {
		"provenance": true,
		"access": "public"
	},
	"repository": {
		"url": "git+https://github.com/phothinmg/susee.git",
		"type": "git"
	},
	"homepage": "https://github.com/phothinmg/susee#readme",
	"bugs": {
		"url": "https://github.com/phothinmg/susee/issues"
	}
}
