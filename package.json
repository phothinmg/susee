{
  "name": "susee",
  "version": "1.5.1",
  "description": "Simple TypeScript Bundler",
  "type": "module",
  "main": "dist/index.cjs",
  "types": "dist/index.d.cts",
  "module": "dist/index.mjs",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "bin": {
    "susee": "bin/index.mjs"
  },
  "scripts": {
    "build": "tsx build.ts",
    "test": "tsx scripts/susee-tests.ts",
    "hooks:install": "bash scripts/install-hooks.sh",
    "fmt": "biome format --write",
    "lint": "biome check src --write",
    "lint:test": "biome check tests --write",
    "commit": "tsx scripts/susee-commit.ts"
  },
  "keywords": [
    "bundler",
    "susee",
    "suseejs"
  ],
  "author": {
    "name": "Pho Thin Mg",
    "email": "phothinmg@disroot.org",
    "url": "https://phothinmg.github.io/"
  },
  "license": "Apache-2.0",
  "dependencies": {
    "@suseejs/resolves": "^0.0.1",
    "@suseejs/tcolor": "^0.1.0",
    "@suseejs/transformer": "^0.1.0",
    "@suseejs/tsconfig": "^0.1.3",
    "@suseejs/types": "^0.2.0",
    "@suseejs/utils": "^0.1.5",
    "mhaehko": "^0.1.0",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.13",
    "@suseejs/plugin-banner-text": "^0.2.0 ",
    "@suseejs/plugin-terser": "^1.0.32",
    "@types/node": "^25.1.0",
    "tsx": "^4.21.0"
  },
  "files": [
    "package.json",
    "README.md",
    "LICENSE",
    "dist/**/*",
    "bin/**/*"
  ],
  "publishConfig": {
    "provenance": true,
    "access": "public"
  },
  "repository": {
    "url": "git+https://github.com/phothinmg/susee.git",
    "type": "git"
  },
  "homepage": "https://github.com/phothinmg/susee#readme",
  "bugs": {
    "url": "https://github.com/phothinmg/susee/issues"
  }
}
